# Application
APP_NAME=dungeon-tycoon-llm
APP_ENV=development
HOST=0.0.0.0
PORT=8000

# LLM backend: "ollama" (default, local) or "anthropic" (cloud)
LLM_BACKEND=ollama

# Ollama (local — install from https://ollama.com)
# Run: ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_PRIMARY_MODEL=mistral
OLLAMA_FAST_MODEL=mistral

# Anthropic (optional — requires API key)
# ANTHROPIC_API_KEY=
# ANTHROPIC_PRIMARY_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# Save directory
SAVE_DIR=./saves
